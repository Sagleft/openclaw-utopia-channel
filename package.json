{
  "name": "openclaw-utopia",
  "version": "2026.3.16",
  "description": "OpenClaw Utopia messenger channel plugin",
  "type": "module",
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "openclaw-utopia",
      "label": "Utopia",
      "selectionLabel": "Utopia (Decentralized Messenger)",
      "docsPath": "/channels/utopia",
      "docsLabel": "utopia",
      "blurb": "Decentralized messenger with crypto support; direct messages via Utopia API.",
      "order": 56,
      "quickstartAllowFrom": true
    },
    "compat": {
      "pluginApi": ">=2026.4.8",
      "minGatewayVersion": "2026.4.8"
    },
    "build": {
      "openclawVersion": "2026.4.8",
      "pluginSdkVersion": "2026.4.8"
    },
    "install": {
      "npmSpec": "openclaw-utopia",
      "localPath": "extensions/utopia",
      "defaultChoice": "npm"
    }
  }
}
